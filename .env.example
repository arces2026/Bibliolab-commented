# .env.example — template per le variabili d ambiente.
#
# ISTRUZIONI:
# 1. Copiate questo file: cp .env.example .env
# 2. Modificate i valori in .env con quelli reali
# 3. MAI committare .env su Git (gia in .gitignore)
#
# Le variabili in questo file vengono lette da docker-compose.yml
# tramite la sintassi ${NOME_VARIABILE}.

# Chiave segreta di Django — deve essere una stringa lunga e casuale.
# Generare con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambiare-con-una-chiave-lunga-e-casuale-minimo-50-caratteri

# Password per il database PostgreSQL
DB_PASSWORD=cambiare-con-una-password-sicura
